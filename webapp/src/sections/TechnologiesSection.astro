---
const techs = [
  {
    name: 'Python',
    version: '3.12',
    icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg',
    desc: 'Cerebro del sistema. Orquesta el entrenamiento, los datos y la API.',
    role: 'Backend / ML',
    color: '#3776AB',
  },
  {
    name: 'TensorFlow',
    version: '2.x',
    icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/tensorflow/tensorflow-original.svg',
    desc: 'Construye y entrena la red neuronal capa por capa con backpropagation.',
    role: 'Deep Learning',
    color: '#FF6F00',
  },
  {
    name: 'NumPy',
    version: '1.x',
    icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/numpy/numpy-original.svg',
    desc: 'Arrays de millas y KM como tensores de alta velocidad.',
    role: 'Datos',
    color: '#013243',
  },
  {
    name: 'FastAPI',
    version: '0.x',
    icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/fastapi/fastapi-original.svg',
    desc: 'Expone el modelo como API REST. La interfaz consume el endpoint /predict.',
    role: 'API',
    color: '#009688',
  },
  {
    name: 'Astro',
    version: '6.x',
    icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/astro/astro-original.svg',
    desc: 'Frontend optimizado. Renderiza la interfaz con máxima velocidad.',
    role: 'Frontend',
    color: '#FF5D01',
  },
  {
    name: 'TypeScript',
    version: '5.x',
    icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg',
    desc: 'Tipado estricto para componentes, lógica e integración con APIs.',
    role: 'Lenguaje',
    color: '#3178C6',
  },
  {
    name: 'Docker',
    version: 'latest',
    icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/docker/docker-original.svg',
    desc: 'Contenedores reproducibles con entorno listo para despliegue.',
    role: 'Infraestructura',
    color: '#2496ED',
  },
  {
    name: 'Tailwind',
    version: '4.x',
    icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/tailwindcss/tailwindcss-original.svg',
    desc: 'Sistema de estilos para interfaz oscura, neon y glassmorphism.',
    role: 'UI',
    color: '#06B6D4',
  },
];
---

<section id="tecnologias" class="relative py-28 px-6">

  <!-- Background glow -->
  <div
    class="absolute left-0 top-1/3 w-96 h-96 opacity-10 pointer-events-none"
    style="background: radial-gradient(circle, #00ff41 0%, transparent 70%)"
  >
  </div>


  <div class="max-w-7xl mx-auto relative">


    <!-- Header -->
    <div class="mb-16 text-center">

      <p class="text-[#00ff41]/40 text-xs tracking-[0.3em] uppercase mb-3">
        // STACK
      </p>

      <h2 class="text-3xl md:text-4xl font-bold text-white">
        Arsenal
        <span class="text-matrix">
          Tecnológico
        </span>
      </h2>

      <p class="text-white/40 mt-3 max-w-lg mx-auto text-sm">
        Cada herramienta cumple una función dentro del pipeline de predicción y entrenamiento del modelo.
      </p>

    </div>


    <!-- Tech Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">


      {techs.map((tech, i) => (

        <div
          class="
            tech-card
            glass-dark
            border border-[#00ff41]/10
            p-5
            group
            relative
            overflow-hidden
            transition-all
            duration-300
            hover:border-[#00ff41]/40
            hover:bg-[#00ff41]/5
            hover:-translate-y-1
          "
          style={`animation-delay:${i * 80}ms`}
        >


          <!-- Hover glow -->
          <div
            class="
              absolute
              inset-0
              opacity-0
              group-hover:opacity-100
              transition-opacity
              duration-500
              pointer-events-none
            "
            style={`background: radial-gradient(circle at top left, ${tech.color}20, transparent 60%)`}
          ></div>



          <!-- Header card -->
          <div class="relative flex items-start justify-between mb-5">


            <!-- Official icon -->
            <div
              class="
                w-12
                h-12
                flex
                items-center
                justify-center
                bg-black/40
                border
                border-white/10
                rounded-md
                transition-all
                duration-300
                group-hover:border-[#00ff41]/40
                group-hover:shadow-[0_0_15px_rgba(0,255,65,0.25)]
              "
            >

              <img
                src={tech.icon}
                alt={tech.name}
                class="
                  w-8
                  h-8
                  object-contain
                  transition-transform
                  duration-300
                  group-hover:scale-110
                "
                loading="lazy"
              />

            </div>



            <!-- Role badge -->
            <span
              class="
                text-[10px]
                tracking-widest
                uppercase
                px-2
                py-1
                border
                bg-black/20
              "
              style={`color:${tech.color}; border-color:${tech.color}50`}
            >
              {tech.role}
            </span>


          </div>



          <!-- Content -->
          <div class="relative">

            <h3 class="text-white font-bold text-base">
              {tech.name}
            </h3>


            <p class="text-[#00ff41]/40 text-[10px] tracking-widest mb-3">
              VERSION {tech.version}
            </p>


            <p class="text-white/40 text-xs leading-relaxed">
              {tech.desc}
            </p>


          </div>




          <!-- Bottom line -->
          <div
            class="
              mt-5
              h-px
              bg-gradient-to-r
              from-transparent
              via-[#00ff41]/20
              to-transparent
              group-hover:via-[#00ff41]/70
              transition-all
              duration-500
            "
          ></div>



        </div>

      ))}


    </div>


  </div>

</section>