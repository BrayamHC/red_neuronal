---
const navLinks = [
  { label: 'Inicio', href: '#inicio' },
  { label: 'Tecnologías', href: '#tecnologias' },
  { label: 'Arquitectura', href: '#arquitectura' },
  { label: 'Predictor', href: '#predictor' },
];
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-40 transition-all duration-300"
>
  <div class="glass-dark border-b border-green-900/40 px-6 py-4">
    <div class="max-w-7xl mx-auto flex items-center justify-between">

<!-- Logo -->
<a href="#inicio" class="flex items-center gap-3 group">

  <div
    class="
      relative
      w-10
      h-10
      border
      border-[#00ff41]/60
      bg-black/50
      flex
      items-center
      justify-center
      overflow-hidden
      transition-all
      duration-300
      group-hover:border-[#00ff41]
      group-hover:shadow-[0_0_20px_rgba(0,255,65,0.45)]
    "
  >

    <!-- Kafka official logo -->
    <img
      src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/apachekafka/apachekafka-original.svg"
      alt="Apache Kafka"
      class="
        w-6
        h-6
        opacity-80
        grayscale
        brightness-0
        invert
        transition-all
        duration-300
        group-hover:scale-110
        group-hover:opacity-100
      "
    />

    <!-- Green neural glow -->
    <span
      class="
        absolute
        inset-0
        bg-[#00ff41]/10
        opacity-0
        group-hover:opacity-100
        transition-opacity
        duration-300
      "
    ></span>


    <!-- Corner decorators -->
    <span class="absolute top-0 left-0 w-1.5 h-1.5 border-t border-l border-[#00ff41]"></span>
    <span class="absolute top-0 right-0 w-1.5 h-1.5 border-t border-r border-[#00ff41]"></span>
    <span class="absolute bottom-0 left-0 w-1.5 h-1.5 border-b border-l border-[#00ff41]"></span>
    <span class="absolute bottom-0 right-0 w-1.5 h-1.5 border-b border-r border-[#00ff41]"></span>


    <!-- Scan line -->
    <span
      class="
        absolute
        left-0
        top-0
        w-full
        h-px
        bg-[#00ff41]
        opacity-40
        animate-[scan_3s_linear_infinite]
      "
    ></span>

  </div>


  <div>
    <span class="text-[#00ff41] font-bold text-lg tracking-widest">
      RED
    </span>

    <span class="text-white/70 font-light text-lg tracking-widest">
      NEURONAL
    </span>
  </div>

</a>

      <!-- Nav -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm text-white/50 hover:text-[#00ff41] transition-colors duration-200 tracking-widest uppercase hover:text-shadow-green relative group"
          >
            {link.label}
            <span class="absolute -bottom-1 left-0 w-0 h-px bg-[#00ff41] transition-all duration-300 group-hover:w-full"></span>
          </a>
        ))}
      </nav>

      <!-- CTA -->
      <a
        href="#predictor"
        class="hidden md:flex items-center gap-2 px-5 py-2 border border-[#00ff41]/60 text-[#00ff41] text-sm tracking-widest uppercase hover:bg-[#00ff41]/10 transition-all duration-200 glow-box"
      >
        <span class="text-xs animate-blink">▶</span>
        Ejecutar
      </a>

      <!-- Mobile menu btn -->
      <button id="menu-btn" class="md:hidden text-[#00ff41] text-xl">☰</button>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('bg-black/80');
    } else {
      header?.classList.remove('bg-black/80');
    }
  });
</script>